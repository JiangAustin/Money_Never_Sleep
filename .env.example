# Copy to .env when local configuration is needed.

MONEY_ENV=development
MONEY_API_HOST=127.0.0.1
MONEY_API_PORT=8000
MONEY_REPORTS_DIR=data/cache/reports

# Reference project locations. Keep these configurable instead of hardcoding machine-specific paths in code.
TRADINGAGENTS_ASTOCK_PATH=../TradingAgents-astock
GO_STOCK_PATH=../go-stock
DAILY_STOCK_ANALYSIS_PATH=../daily_stock_analysis

# Optional TradingAgents deep engine integration. Keep disabled unless explicitly running stage 3 smoke.
MNS_RUN_TRADINGAGENTS_SMOKE=0
TRADINGAGENTS_RESULTS_DIR=data/cache/tradingagents/results
TRADINGAGENTS_CACHE_DIR=data/cache/tradingagents/cache
