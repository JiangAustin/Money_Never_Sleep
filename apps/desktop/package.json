{
  "name": "money-never-sleep-desktop",
  "version": "0.1.0",
  "description": "Desktop shell for Money_Never_sleep",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dev.moneyneversleep.desktop",
    "productName": "Money Never Sleep",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.finance"
    }
  }
}
